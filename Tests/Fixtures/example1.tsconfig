mod.tx_bwfocuspointimages.settings.fields {
  title {
    title = LLL:EXT:bw_focuspoint_images/Resources/Private/Language/locallang_db.xlf:wizard.fields.title
    type = text
    useAsName = 1
  }

  overlay_color {
    title = Overlay Color
    type = color
    useAsOverlayColor = 1
    default = #000000
  }

  opacity {
    title = Overlay Opacity
    type = number
    slider {
      step = 0.1
    }
    range {
      lower = 0
      upper = 1
    }
    default = 0.3
    useAsOverlayOpacity = 1
  }

  opacity_hover {
    title = Overlay Opacity on Hover
    type = number
    slider {
      step = 0.1
    }
    range {
      lower = 0
      upper = 1
    }
    default = 0.5
    useAsOverlayOpacityOnHover = 1
  }

  hasLink {
    title = hat link
    type = checkbox
    label = yes
    default = true
  }

  link {
    title = LLL:EXT:bw_focuspoint_images/Resources/Private/Language/locallang_db.xlf:wizard.fields.link
    type = link
    displayCond = FIELD:hasLink:REQ:true
  }
}
