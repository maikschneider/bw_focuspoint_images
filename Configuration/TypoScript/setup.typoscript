tt_content.bw_focuspoint_images_svg =<  lib.contentElement
tt_content.bw_focuspoint_images_svg {
  templateName = FocuspointImage

  templateRootPaths.1 = EXT:bw_focuspoint_images/Resources/Private/Templates/
  templateRootPaths.10 = {$plugin.tx_bwfocuspointimages.view.templateRootPath}
  partialRootPaths.1 = EXT:bw_focuspoint_images/Resources/Private/Partials/
  partialRootPaths.10 = {$plugin.tx_bwfocuspointimages.view.partialRootPath}
  layoutRootPaths.1 = EXT:bw_focuspoint_images/Resources/Private/Layouts/
  layoutRootPaths.10 = {$plugin.tx_bwfocuspointimages.view.layoutRootPath}

  dataProcessing {
    10 = Blueways\BwFocuspointImages\DataProcessing\FocuspointProcessor
    10 {
      references.fieldName = assets
      as = images
    }
  }
}
